<div class="mx-auto max-w-md animate-slideIn">
  <div class="rounded-2xl border border-slate-700/50 bg-slate-900/50 backdrop-blur p-8 shadow-2xl">
    <div class="mb-8 text-center">
      <div class="inline-flex h-12 w-12 items-center justify-center rounded-lg bg-gradient-to-br from-purple-500 to-pink-500 text-2xl font-bold text-white shadow-lg shadow-purple-500/30 mb-4">🔐</div>
      <h1 class="text-3xl font-bold text-white">Nueva contraseña</h1>
      <p class="mt-2 text-slate-400 text-sm">Establece una contraseña segura para tu cuenta</p>
    </div>

    <%= form_with url: password_path(params[:token]), method: :put, class: "space-y-6" do |form| %>
      <div>
        <label class="block text-sm font-semibold text-slate-200 mb-2" for="password">Nueva contraseña</label>
        <%= form.password_field :password, required: true, autocomplete: "new-password", placeholder: "Mínimo 8 caracteres", maxlength: 72, class: "w-full rounded-lg border border-slate-700 bg-slate-950 px-4 py-3 text-slate-100 placeholder-slate-500 focus:border-purple-500 focus:outline-none focus:ring-2 focus:ring-purple-500/20 transition" %>
      </div>

      <div>
        <label class="block text-sm font-semibold text-slate-200 mb-2" for="password_confirmation">Confirmar contraseña</label>
        <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password", placeholder: "Repite tu nueva contraseña", maxlength: 72, class: "w-full rounded-lg border border-slate-700 bg-slate-950 px-4 py-3 text-slate-100 placeholder-slate-500 focus:border-purple-500 focus:outline-none focus:ring-2 focus:ring-purple-500/20 transition" %>
      </div>

      <p class="text-xs text-slate-400 italic">
        Utiliza una contraseña segura con al menos 8 caracteres, incluyendo mayúsculas, minúsculas y números.
      </p>

      <%= form.submit "Guardar contraseña", class: "w-full inline-flex items-center justify-center rounded-lg bg-gradient-to-r from-purple-600 to-pink-600 px-6 py-3 text-base font-semibold text-white shadow-lg shadow-purple-500/30 hover:shadow-purple-500/50 transition" %>
    <% end %>

    <div class="mt-6 text-center">
      <p class="text-sm text-slate-400">
        ¿Ya tiene una contraseña? 
        <%= link_to "Inicia sesión", new_session_path, class: "font-semibold text-blue-400 hover:text-blue-300 transition" %>
      </p>
    </div>
  </div>
</div>
