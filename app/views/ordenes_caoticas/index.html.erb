<% content_for :title, "Dashboard — Market Caótica" %>

<%
  ciudad_colors = {
    "Santa Cruz"  => { bg: "bg-blue-500/15",   border: "border-blue-500/40",   text: "text-blue-300",   dot: "bg-blue-400"   },
    "La Paz"      => { bg: "bg-violet-500/15",  border: "border-violet-500/40", text: "text-violet-300", dot: "bg-violet-400" },
    "Cochabamba"  => { bg: "bg-emerald-500/15", border: "border-emerald-500/40",text: "text-emerald-300",dot: "bg-emerald-400" }
  }
  def_color = { bg: "bg-slate-500/15", border: "border-slate-500/40", text: "text-slate-300", dot: "bg-slate-400" }
%>

<div class="space-y-10">

  <!-- ═══ PAGE HEADER ═══ -->
  <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 reveal">
    <div class="space-y-1">
      <div class="inline-flex items-center gap-2 rounded-full bg-amber-500/15 border border-amber-500/30 px-4 py-1.5 text-xs font-semibold text-amber-300 uppercase tracking-wider">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-amber-400 opacity-75"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-amber-400"></span>
        </span>
        Sistema en vivo
      </div>
      <h1 class="text-3xl md:text-4xl font-black text-white tracking-tight">
        Dashboard de Órdenes
      </h1>
      <p class="text-slate-400 text-sm">Gestión de ventas del Mini Market Caótica • Bolivia</p>
    </div>

    <!-- User info + logout -->
    <div class="flex items-center gap-3">
      <div class="flex items-center gap-2.5 rounded-full border border-slate-700/60 bg-slate-800/50 px-4 py-2 backdrop-blur">
        <div class="h-7 w-7 rounded-full bg-gradient-to-br from-amber-400 to-orange-500 flex items-center justify-center text-xs font-bold text-white">
          <%= Current.user.email_address[0].upcase %>
        </div>
        <span class="text-sm text-slate-300 font-medium"><%= Current.user.email_address %></span>
      </div>
      <%= link_to "Salir →", session_path, data: { turbo_method: :delete },
          class: "inline-flex items-center gap-1.5 rounded-xl border border-red-500/30 bg-red-500/10 px-4 py-2 text-sm font-medium text-red-300 hover:bg-red-500/20 hover:border-red-500/50 transition duration-200" %>
    </div>
  </div>

  <!-- ═══ KPI CARDS ═══ -->
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">

    <!-- Total Ventas -->
    <div class="group relative rounded-2xl border border-amber-500/20 bg-gradient-to-br from-amber-500/8 to-orange-500/5 backdrop-blur p-6 reveal hover:border-amber-500/40 transition duration-300" data-delay="0">
      <div class="absolute top-4 right-4 h-10 w-10 rounded-xl bg-amber-500/15 flex items-center justify-center text-xl group-hover:scale-110 transition duration-300">💰</div>
      <p class="text-xs font-semibold text-amber-400/80 uppercase tracking-wider mb-2">Total Ventas</p>
      <p class="text-3xl font-black text-white">Bs. <%= number_with_precision(@total_ventas, precision: 2, delimiter: ',') %></p>
      <p class="text-xs text-slate-500 mt-1">Ingresos acumulados</p>
    </div>

    <!-- Total Órdenes -->
    <div class="group relative rounded-2xl border border-blue-500/20 bg-gradient-to-br from-blue-500/8 to-cyan-500/5 backdrop-blur p-6 reveal hover:border-blue-500/40 transition duration-300" data-delay="80">
      <div class="absolute top-4 right-4 h-10 w-10 rounded-xl bg-blue-500/15 flex items-center justify-center text-xl group-hover:scale-110 transition duration-300">📋</div>
      <p class="text-xs font-semibold text-blue-400/80 uppercase tracking-wider mb-2">Total Órdenes</p>
      <p class="text-3xl font-black text-white"><%= @total_ordenes %></p>
      <p class="text-xs text-slate-500 mt-1">Transacciones registradas</p>
    </div>

    <!-- Clientes Únicos -->
    <div class="group relative rounded-2xl border border-emerald-500/20 bg-gradient-to-br from-emerald-500/8 to-teal-500/5 backdrop-blur p-6 reveal hover:border-emerald-500/40 transition duration-300" data-delay="160">
      <div class="absolute top-4 right-4 h-10 w-10 rounded-xl bg-emerald-500/15 flex items-center justify-center text-xl group-hover:scale-110 transition duration-300">👥</div>
      <p class="text-xs font-semibold text-emerald-400/80 uppercase tracking-wider mb-2">Clientes Únicos</p>
      <p class="text-3xl font-black text-white"><%= @clientes_unicos %></p>
      <p class="text-xs text-slate-500 mt-1">Clientes distintos</p>
    </div>

    <!-- Promedio por Orden -->
    <div class="group relative rounded-2xl border border-violet-500/20 bg-gradient-to-br from-violet-500/8 to-purple-500/5 backdrop-blur p-6 reveal hover:border-violet-500/40 transition duration-300" data-delay="240">
      <div class="absolute top-4 right-4 h-10 w-10 rounded-xl bg-violet-500/15 flex items-center justify-center text-xl group-hover:scale-110 transition duration-300">📊</div>
      <p class="text-xs font-semibold text-violet-400/80 uppercase tracking-wider mb-2">Promedio / Orden</p>
      <p class="text-3xl font-black text-white">Bs. <%= number_with_precision(@promedio_orden, precision: 2) %></p>
      <p class="text-xs text-slate-500 mt-1">Ticket promedio</p>
    </div>
  </div>

  <!-- ═══ CHARTS ROW ═══ -->
  <div class="grid lg:grid-cols-2 gap-6">

    <!-- Ventas por Ciudad -->
    <div class="rounded-2xl border border-slate-700/50 bg-slate-800/20 backdrop-blur p-6 reveal">
      <h2 class="text-base font-bold text-white mb-5 flex items-center gap-2">
        <span class="h-5 w-1 rounded-full bg-gradient-to-b from-amber-400 to-orange-500"></span>
        Ventas por Ciudad
      </h2>
      <div class="space-y-3">
        <% max_city = @ventas_por_ciudad.map { |_, v| v }.max || 1 %>
        <% city_palette = { "Santa Cruz" => "from-blue-500 to-cyan-500", "La Paz" => "from-violet-500 to-purple-500", "Cochabamba" => "from-emerald-500 to-teal-500" } %>
        <% @ventas_por_ciudad.each do |ciudad, total| %>
          <div class="space-y-1">
            <div class="flex justify-between items-center text-xs">
              <span class="font-medium text-slate-300"><%= ciudad %></span>
              <span class="font-bold text-white">Bs. <%= number_with_precision(total, precision: 2) %></span>
            </div>
            <div class="h-2.5 w-full bg-slate-700/60 rounded-full overflow-hidden">
              <div class="h-full rounded-full bg-gradient-to-r <%= city_palette[ciudad] || 'from-slate-500 to-slate-400' %> transition-all duration-700"
                   style="width: <%= (total / max_city * 100).round %>%"></div>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Ventas por Vendedor -->
    <div class="rounded-2xl border border-slate-700/50 bg-slate-800/20 backdrop-blur p-6 reveal" data-delay="100">
      <h2 class="text-base font-bold text-white mb-5 flex items-center gap-2">
        <span class="h-5 w-1 rounded-full bg-gradient-to-b from-violet-400 to-purple-500"></span>
        Rendimiento por Vendedor
      </h2>
      <div class="space-y-3">
        <% max_v = @ventas_por_vendedor.map { |_, v| v }.max || 1 %>
        <% vendedor_palette = ["from-amber-500 to-orange-500", "from-violet-500 to-pink-500", "from-blue-500 to-indigo-500"] %>
        <% @ventas_por_vendedor.each_with_index do |(vendedor, total), i| %>
          <div class="space-y-1">
            <div class="flex justify-between items-center text-xs">
              <span class="font-medium text-slate-300"><%= vendedor %></span>
              <span class="font-bold text-white">Bs. <%= number_with_precision(total, precision: 2) %></span>
            </div>
            <div class="h-2.5 w-full bg-slate-700/60 rounded-full overflow-hidden">
              <div class="h-full rounded-full bg-gradient-to-r <%= vendedor_palette[i % vendedor_palette.size] %> transition-all duration-700"
                   style="width: <%= (total / max_v * 100).round %>%"></div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- ═══ FILTERS + TABLE ═══ -->
  <div class="rounded-2xl border border-slate-700/50 bg-slate-800/15 backdrop-blur overflow-hidden reveal">

    <!-- Table Header + Filters -->
    <div class="p-6 border-b border-slate-700/40 space-y-4">
      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3">
        <h2 class="text-base font-bold text-white flex items-center gap-2">
          <span class="h-5 w-1 rounded-full bg-gradient-to-b from-amber-400 to-orange-500"></span>
          Registro de Órdenes
          <span class="ml-1 text-xs font-normal text-slate-500">(<%= @ordenes.count %> resultados)</span>
        </h2>
        <% if @ciudad.present? || @vendedor.present? || @busqueda.present? %>
          <%= link_to "✕ Limpiar filtros", ordenes_caoticas_path,
              class: "text-xs text-amber-400 hover:text-amber-300 border border-amber-500/30 rounded-lg px-3 py-1.5 hover:bg-amber-500/10 transition" %>
        <% end %>
      </div>

      <!-- Filter form -->
      <%= form_with url: ordenes_caoticas_path, method: :get, local: true, class: "flex flex-wrap gap-3" do |f| %>
        <!-- Search by client -->
        <div class="relative">
          <span class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-500 text-sm">🔍</span>
          <%= f.text_field :q, value: @busqueda, placeholder: "Buscar cliente...",
              class: "pl-9 pr-4 py-2 text-sm bg-slate-700/50 border border-slate-600/50 rounded-xl text-white placeholder-slate-500 focus:outline-none focus:border-amber-500/50 focus:ring-1 focus:ring-amber-500/30 transition w-48" %>
        </div>

        <!-- Filter by city -->
        <%= f.select :ciudad,
            options_for_select([["🌍 Todas las ciudades", ""]] + @ciudades.map { |c| [c, c] }, @ciudad),
            {},
            class: "px-4 py-2 text-sm bg-slate-700/50 border border-slate-600/50 rounded-xl text-white focus:outline-none focus:border-amber-500/50 transition cursor-pointer" %>

        <!-- Filter by vendor -->
        <%= f.select :vendedor,
            options_for_select([["👤 Todos los vendedores", ""]] + @vendedores.map { |v| [v, v] }, @vendedor),
            {},
            class: "px-4 py-2 text-sm bg-slate-700/50 border border-slate-600/50 rounded-xl text-white focus:outline-none focus:border-amber-500/50 transition cursor-pointer" %>

        <%= f.submit "Filtrar",
            class: "px-5 py-2 text-sm font-semibold bg-gradient-to-r from-amber-500 to-orange-500 text-white rounded-xl hover:from-amber-400 hover:to-orange-400 transition cursor-pointer shadow-lg shadow-amber-500/20" %>
      <% end %>
    </div>

    <!-- Table -->
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-slate-700/50 bg-slate-900/30">
            <th class="px-4 py-3.5 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">#</th>
            <th class="px-4 py-3.5 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">Fecha</th>
            <th class="px-4 py-3.5 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">Cliente</th>
            <th class="px-4 py-3.5 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">DNI</th>
            <th class="px-4 py-3.5 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">Productos</th>
            <th class="px-4 py-3.5 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">Sucursal</th>
            <th class="px-4 py-3.5 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">Ciudad</th>
            <th class="px-4 py-3.5 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">Vendedor</th>
            <th class="px-4 py-3.5 text-right text-xs font-semibold text-slate-400 uppercase tracking-wider">Total</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-700/30">
          <% @ordenes.each_with_index do |orden, i| %>
            <%
              colors = ciudad_colors[orden.sucursal_ciudad] || def_color
            %>
            <tr class="hover:bg-slate-700/20 transition duration-150 group">
              <td class="px-4 py-3.5 text-slate-500 font-mono text-xs">#<%= orden.id_orden %></td>
              <td class="px-4 py-3.5 text-slate-300 whitespace-nowrap">
                <%= orden.fecha&.strftime("%d %b %Y") %>
              </td>
              <td class="px-4 py-3.5">
                <div class="flex items-center gap-2">
                  <div class="h-7 w-7 rounded-full bg-gradient-to-br from-amber-400/30 to-orange-500/30 border border-amber-500/20 flex items-center justify-center text-xs font-bold text-amber-300 shrink-0">
                    <%= orden.cliente_nombre[0] %>
                  </div>
                  <div>
                    <p class="font-medium text-white text-xs"><%= orden.cliente_nombre %></p>
                    <p class="text-slate-500 text-xs truncate max-w-[140px]"><%= orden.cliente_direccion %></p>
                  </div>
                </div>
              </td>
              <td class="px-4 py-3.5 text-slate-400 font-mono text-xs"><%= orden.cliente_dni %></td>
              <td class="px-4 py-3.5 text-slate-300 text-xs max-w-[160px]">
                <div class="flex flex-wrap gap-1">
                  <% orden.items_comprados.split(", ").each do |item| %>
                    <span class="inline-flex items-center rounded-md bg-slate-700/60 border border-slate-600/40 px-1.5 py-0.5 text-xs text-slate-300">
                      <%= item.strip %>
                    </span>
                  <% end %>
                </div>
              </td>
              <td class="px-4 py-3.5 text-slate-400 text-xs whitespace-nowrap"><%= orden.sucursal_nombre %></td>
              <td class="px-4 py-3.5">
                <span class="inline-flex items-center gap-1.5 rounded-full <%= colors[:bg] %> border <%= colors[:border] %> px-2.5 py-1 text-xs font-semibold <%= colors[:text] %> whitespace-nowrap">
                  <span class="h-1.5 w-1.5 rounded-full <%= colors[:dot] %>"></span>
                  <%= orden.sucursal_ciudad %>
                </span>
              </td>
              <td class="px-4 py-3.5 text-slate-300 text-xs whitespace-nowrap"><%= orden.vendedor_nombre %></td>
              <td class="px-4 py-3.5 text-right">
                <span class="font-bold text-amber-300">Bs. <%= number_with_precision(orden.precio_total, precision: 2) %></span>
              </td>
            </tr>
          <% end %>
          <% if @ordenes.empty? %>
            <tr>
              <td colspan="9" class="px-4 py-16 text-center">
                <div class="space-y-2">
                  <div class="text-4xl">🔍</div>
                  <p class="text-slate-400 font-medium">No se encontraron órdenes</p>
                  <p class="text-slate-600 text-xs">Intenta con otros filtros</p>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
        <!-- Totals row -->
        <% unless @ordenes.empty? %>
          <tfoot>
            <tr class="border-t border-amber-500/20 bg-amber-500/5">
              <td colspan="8" class="px-4 py-3.5 text-xs font-semibold text-amber-400/80 uppercase tracking-wider">
                Subtotal filtrado (<%= @ordenes.count %> órdenes)
              </td>
              <td class="px-4 py-3.5 text-right font-black text-amber-300">
                Bs. <%= number_with_precision(@ordenes.sum(:precio_total), precision: 2) %>
              </td>
            </tr>
          </tfoot>
        <% end %>
      </table>
    </div>
  </div>

</div>
