<!DOCTYPE html>
<html lang="es">
  <head>
    <title><%= content_for(:title) || "Auth App" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <style>
      * { font-family: 'Inter', sans-serif; }
      code, pre { font-family: 'JetBrains Mono', monospace; }
    </style>
  </head>

  <body class="min-h-screen bg-gradient-to-br from-slate-950 via-slate-950 to-blue-950 text-slate-100"
        data-controller="animations">

    <!-- Progress bar -->
    <div id="page-progress"></div>

    <!-- Particles canvas -->
    <canvas id="particles-canvas"></canvas>

    <!-- Spotlight -->
    <div class="spotlight"></div>

    <!-- Background ambient blobs -->
    <div class="fixed inset-0 -z-20 overflow-hidden pointer-events-none">
      <div class="absolute top-0 -left-40 w-96 h-96 bg-blue-500/8 rounded-full blur-3xl animate-glow-pulse"></div>
      <div class="absolute -top-40 right-0 w-96 h-96 bg-cyan-500/8 rounded-full blur-3xl animate-glow-pulse" style="animation-delay:1.5s"></div>
      <div class="absolute bottom-0 left-1/3 w-80 h-80 bg-violet-500/5 rounded-full blur-3xl animate-glow-pulse" style="animation-delay:3s"></div>
    </div>

    <!-- ════════════════════════ HEADER ════════════════════════ -->
    <header class="sticky top-0 z-50 border-b border-slate-800/40 bg-slate-950/60 backdrop-blur-2xl transition-all duration-300">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="flex h-18 items-center justify-between py-4">

          <!-- Logo -->
          <div class="flex items-center gap-3">
            <div class="relative flex h-11 w-11 items-center justify-center rounded-xl bg-gradient-to-br from-blue-500 to-cyan-500 text-lg font-bold text-white shadow-lg animate-glow-pulse hover:scale-110 transition duration-300">
              🔐
              <div class="absolute inset-0 rounded-xl bg-gradient-to-br from-blue-500 to-cyan-500 blur-md opacity-50 -z-10"></div>
            </div>
            <%= link_to "Auth App", root_path, class: "text-xl font-black tracking-tight text-white hover:text-blue-300 transition nav-link" %>
          </div>

          <!-- Navigation -->
          <nav class="hidden md:flex items-center gap-8">
            <% if authenticated? %>
              <div class="flex items-center gap-3">
                <div class="flex items-center gap-2 rounded-full border border-emerald-500/30 bg-emerald-500/10 px-4 py-1.5">
                  <span class="relative flex h-2 w-2">
                    <span class="animate-ping-slow absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                    <span class="relative inline-flex h-2 w-2 rounded-full bg-emerald-500"></span>
                  </span>
                  <span class="text-xs font-medium text-emerald-300"><%= Current.user.email_address %></span>
                </div>
                <%= link_to "Cerrar sesión", session_path, data: { turbo_method: :delete },
                    class: "inline-flex items-center gap-2 rounded-lg bg-red-600/15 border border-red-500/25 px-4 py-2 text-sm font-medium text-red-300 hover:bg-red-600/30 hover:border-red-500/50 transition duration-200" %>
              </div>
            <% else %>
              <%= link_to "Iniciar sesión", new_session_path,
                  class: "text-sm font-medium text-slate-300 hover:text-white transition nav-link" %>
              <%= link_to "Registrarse", new_registration_path,
                  class: "ripple-container inline-flex items-center gap-2 rounded-lg bg-gradient-to-r from-blue-600 to-cyan-600 px-5 py-2.5 text-sm font-semibold text-white shadow-lg shadow-blue-500/30 hover:shadow-blue-500/50 hover:scale-105 transition duration-200 btn-glow" %>
            <% end %>
          </nav>

          <!-- Mobile menu -->
          <div class="md:hidden flex items-center gap-3">
            <% if authenticated? %>
              <%= link_to "Salir", session_path, data: { turbo_method: :delete }, class: "text-sm font-medium text-red-300 hover:text-red-200 transition" %>
            <% else %>
              <%= link_to "Ingresar", new_session_path, class: "text-sm font-medium text-blue-300 hover:text-blue-200 transition" %>
            <% end %>
          </div>
        </div>
      </div>
    </header>

    <!-- ════════════════════════ MAIN ════════════════════════ -->
    <main class="relative animate-fade-in">
      <% if notice %>
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-6">
          <div class="animate-bounce-in rounded-2xl border border-emerald-500/30 bg-emerald-500/10 p-4 backdrop-blur-sm flex items-center gap-3 glass-morphism">
            <span class="text-xl">✓</span>
            <p class="text-sm font-medium text-emerald-200"><%= notice %></p>
            <button onclick="this.parentElement.parentElement.remove()" class="ml-auto text-emerald-400 hover:text-emerald-200 transition text-lg leading-none">&times;</button>
          </div>
        </div>
      <% end %>

      <% if alert %>
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-6">
          <div class="animate-bounce-in rounded-2xl border border-red-500/30 bg-red-500/10 p-4 backdrop-blur-sm flex items-center gap-3 glass-morphism">
            <span class="text-xl">⚠</span>
            <p class="text-sm font-medium text-red-200"><%= alert %></p>
            <button onclick="this.parentElement.parentElement.remove()" class="ml-auto text-red-400 hover:text-red-200 transition text-lg leading-none">&times;</button>
          </div>
        </div>
      <% end %>

      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-6 sm:py-12">
        <%= yield %>
      </div>
    </main>

    <!-- ════════════════════════ FOOTER ════════════════════════ -->
    <footer class="border-t border-slate-800/40 bg-slate-950/50 backdrop-blur py-12 mt-24">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid md:grid-cols-3 gap-8 mb-8">
          <div class="space-y-3">
            <div class="flex items-center gap-2">
              <div class="h-7 w-7 rounded-lg bg-gradient-to-br from-blue-500 to-cyan-500 flex items-center justify-center text-sm">🔐</div>
              <h3 class="font-bold text-white">Auth App</h3>
            </div>
            <p class="text-sm text-slate-400 leading-relaxed">Sistema profesional de autenticación y gestión de sesiones.</p>
          </div>
          <div class="space-y-3">
            <h3 class="font-bold text-white">Tecnología</h3>
            <ul class="text-sm text-slate-400 space-y-1.5">
              <li class="flex items-center gap-2"><span class="text-blue-400">▸</span> Rails 8</li>
              <li class="flex items-center gap-2"><span class="text-blue-400">▸</span> PostgreSQL</li>
              <li class="flex items-center gap-2"><span class="text-blue-400">▸</span> Tailwind CSS</li>
            </ul>
          </div>
          <div class="space-y-3">
            <h3 class="font-bold text-white">Info</h3>
            <p class="text-sm text-slate-400">Versión 1.0 • 2026</p>
            <div class="flex items-center gap-1.5">
              <span class="h-1.5 w-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
              <span class="text-xs text-emerald-400 font-medium">Todos los sistemas activos</span>
            </div>
          </div>
        </div>
        <div class="border-t border-slate-800/50 pt-8 text-center text-sm text-slate-500">
          <p>© 2026 Auth App. Todos los derechos reservados.</p>
        </div>
      </div>
    </footer>
  </body>
</html>
